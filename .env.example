# .env.example — copy to .env and fill in values
# ================================================
# Coffee Quant environment configuration.
# All variables are optional; the system falls back to free public sources.

# FRED API key (free at https://fred.stlouisfed.org/docs/api/api_key.html)
# Used for: USD/BRL, EUR/USD, USD/VND FX rates
# Fallback: Yahoo Finance (no key required)
COFFEE_FRED_API_KEY=

# NOAA API token (free at https://www.ncdc.noaa.gov/cdo-web/token)
# Used for: extended climate data
# Fallback: NOAA public URLs (no key required for ONI)
COFFEE_NOAA_API_TOKEN=

# Data directory override (defaults to ./data/)
# COFFEE_PROJECT_ROOT=/path/to/your/data/root

# Date range defaults
COFFEE_DEFAULT_START_DATE=2010-01-01
COFFEE_DEFAULT_END_DATE=2024-12-31

# Logging
COFFEE_LOG_LEVEL=INFO

# HMM configuration
COFFEE_HMM_N_REGIMES=3

# GARCH configuration
COFFEE_GARCH_P=1
COFFEE_GARCH_Q=1
COFFEE_GARCH_DIST=t

# Backtesting windows
COFFEE_BACKTEST_TRAIN_WINDOW_DAYS=756
COFFEE_BACKTEST_TEST_WINDOW_DAYS=63
COFFEE_BACKTEST_N_FOLDS=5
